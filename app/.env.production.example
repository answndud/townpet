# TownPet production runtime environment template
# This file mirrors the keys used in Vercel Production.
# Do not put real secrets in this file.
# GitHub Actions secrets are managed separately in repository settings.

NODE_ENV=production

# Application URLs / database
APP_BASE_URL=https://townpet.example.com
NEXTAUTH_URL=https://townpet.example.com
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require

# Auth
# Generate 32+ random characters. Use a strong random value.
AUTH_SECRET=REPLACE_WITH_32_PLUS_RANDOM_CHARS

# Security hardening
# Generate a separate random secret, different from AUTH_SECRET.
GUEST_HASH_PEPPER=REPLACE_WITH_RANDOM_PEPPER
# Generate a separate random secret for internal health diagnostics.
HEALTH_INTERNAL_TOKEN=REPLACE_WITH_RANDOM_HEALTH_TOKEN
# Recommended: enable strict nonce CSP in production after preview verification.
CSP_ENFORCE_STRICT=1
ENABLE_SOCIAL_DEV_LOGIN=0

# Rate limit / cache
UPSTASH_REDIS_REST_URL=https://YOUR_UPSTASH_INSTANCE.upstash.io
UPSTASH_REDIS_REST_TOKEN=REPLACE_WITH_UPSTASH_TOKEN

# Uploads
BLOB_READ_WRITE_TOKEN=REPLACE_WITH_VERCEL_BLOB_TOKEN

# Email
RESEND_API_KEY=REPLACE_WITH_RESEND_API_KEY

# Error monitoring
SENTRY_DSN=REPLACE_WITH_SENTRY_DSN

# OAuth providers
KAKAO_CLIENT_ID=REPLACE_WITH_KAKAO_CLIENT_ID
KAKAO_CLIENT_SECRET=REPLACE_WITH_KAKAO_CLIENT_SECRET
NAVER_CLIENT_ID=REPLACE_WITH_NAVER_CLIENT_ID
NAVER_CLIENT_SECRET=REPLACE_WITH_NAVER_CLIENT_SECRET

# Optional runtime flags
# Do not enable demo auth fallback in shared or production environments.
CORS_ORIGIN=https://townpet.example.com
QUERY_CACHE_ENABLED=1

# Reference only: GitHub Actions secrets used by workflows
# AUTH_SECRET
# DATABASE_URL
# HEALTH_INTERNAL_TOKEN
# KAKAO_CLIENT_ID
# KAKAO_CLIENT_SECRET
# NAVER_CLIENT_ID
# NAVER_CLIENT_SECRET
# SENTRY_AUTH_TOKEN
# SENTRY_DSN
# SENTRY_ORG_SLUG
# SENTRY_PROJECT_SLUG
