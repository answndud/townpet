# TownPet local development environment template
# Copy this file to app/.env and replace values only when needed.
# Do not put production secrets in app/.env.

NODE_ENV=development

# Local PostgreSQL from docker-compose
DATABASE_URL="postgresql://townpet:townpet@localhost:5432/townpet?schema=public"

# Local app/auth URLs
APP_BASE_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"

# Local-only weak secret. Replace with a 32+ char random value outside local dev.
AUTH_SECRET="dev-local-nextauth-secret-2026-01-25"
NEXTAUTH_SECRET="dev-local-nextauth-secret-2026-01-25"

# Local seed defaults
DEMO_USER_EMAIL="demo@townpet.dev"
SEED_DEFAULT_PASSWORD="townpet123"
AUTH_AUDIT_RETENTION_DAYS="180"

# Optional local integrations
RESEND_API_KEY=""
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
BLOB_READ_WRITE_TOKEN=""
SENTRY_DSN=""
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""

# Local-only feature flags
ENABLE_SOCIAL_DEV_LOGIN="0"
ENABLE_DEMO_AUTH_FALLBACK="0"
QUERY_CACHE_ENABLED="1"
